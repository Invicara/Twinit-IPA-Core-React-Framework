{
  "name": "root",
  "private": true,
  "scripts": {
    "bootstrap": "npm install",
    "build": "lerna run build",
    "build-dev": "lerna run build-dev",
    "release": "npm run build && lerna version --exact",
    "quickrelease": "lerna version --exact",
    "changed": "lerna changed",
    "publish": "lerna run build && lerna publish from-package --yes",
    "prepare": "husky install"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.1",
    "eslint-plugin-react-hooks": "^4.6.0",
    "husky": "^8.0.0",
    "lerna": "^9.0.7",
    "lint-staged": "^15.2.2"
  },
  "lint-staged": {
    "**/*.{js,jsx,ts,tsx}": [
      "npx prettier --write",
      "npx eslint --fix"
    ]
  },
  "workspaces": [
    "packages/*"
  ],
  "overrides": {
    "flatted": "^3.4.2",
    "minimatch@<3.1.3": "^3.1.4",
    "lodash@<4.18.0": "^4.18.1",
    "tar": "^7.5.16",
    "uuid@<11.1.1": "^11.1.1"
  }
}
